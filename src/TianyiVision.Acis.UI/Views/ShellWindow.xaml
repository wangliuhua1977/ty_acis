<Window x:Class="TianyiVision.Acis.UI.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Width="1520"
        Height="920"
        MinWidth="1280"
        MinHeight="720"
        Title="{Binding ApplicationName}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="ShellStatusMetricButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Theme.SelectionBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.SelectionBorderBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Margin="16"
            Background="{DynamicResource Theme.ShellGradientBrush}"
            BorderBrush="{DynamicResource Theme.PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="24">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="14"
                    Background="{DynamicResource Theme.SidebarBackgroundBrush}"
                    BorderBrush="{DynamicResource Theme.PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource AccentTextStyle}" Text="ACIS SHELL" />
                        <TextBlock Margin="0,8,0,0"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Theme.TextPrimaryBrush}"
                                   Text="{Binding ApplicationName}" />
                        <TextBlock Margin="0,10,0,0"
                                   Style="{StaticResource PageDescriptionTextStyle}"
                                   Text="{Binding SidebarDescription}" />
                    </StackPanel>

                    <ItemsControl Grid.Row="1" Margin="0,26,0,0" ItemsSource="{Binding NavigationItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource NavButtonStyle}"
                                        Command="{Binding SelectCommand}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="44"
                                                Height="44"
                                                Background="{DynamicResource Theme.AccentSoftBrush}"
                                                BorderBrush="{DynamicResource Theme.PanelBorderStrongBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Theme.TextPrimaryBrush}"
                                                       Text="{Binding ShortCode}" />
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Margin="14,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Theme.TextPrimaryBrush}"
                                                   Text="{Binding Label}" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Grid.Row="2" Style="{StaticResource MutedPanelStyle}" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Style="{StaticResource MetricTitleTextStyle}" Text="{Binding CurrentUserLabel}" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Theme.TextPrimaryBrush}"
                                       Text="{Binding CurrentUserValue}" />
                            <TextBlock Margin="0,14,0,0" Style="{StaticResource MetricTitleTextStyle}" Text="{Binding CurrentTimeLabel}" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="16"
                                       Foreground="{DynamicResource Theme.TextPrimaryBrush}"
                                       Text="{Binding CurrentTimeText}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="0,14,14,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Margin="0,0,0,10"
                        Padding="10"
                        Background="{DynamicResource Theme.PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource Theme.PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="260" />
                        </Grid.ColumnDefinitions>

                        <ItemsControl ItemsSource="{Binding HeaderMetrics}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1" Columns="5" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource ShellStatusMetricButtonStyle}"
                                            Command="{Binding DataContext.SelectHeaderMetricCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Left" Style="{StaticResource MetricTitleTextStyle}" Text="{Binding Title}" />
                                            <TextBlock DockPanel.Dock="Right" FontSize="18" FontWeight="SemiBold" Text="{Binding Value}" />
                                        </DockPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Grid.Column="1"
                                Margin="12,0,0,0"
                                Padding="10,8"
                                Background="{DynamicResource Theme.PanelMutedBackgroundBrush}"
                                BorderBrush="{DynamicResource Theme.PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12">
                            <TextBlock Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding HeaderStatusFeedback}" />
                        </Border>
                    </Grid>
                </Border>

                <ContentControl x:Name="CurrentPageHost"
                                Grid.Row="1"
                                Content="{Binding CurrentPageViewModel}" />
            </Grid>
        </Grid>
    </Border>
</Window>

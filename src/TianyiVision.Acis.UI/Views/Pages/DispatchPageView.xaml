<UserControl x:Class="TianyiVision.Acis.UI.Views.Pages.DispatchPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,20">
            <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="{Binding Title}" />
            <TextBlock Margin="0,10,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding Description}" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <ItemsControl ItemsSource="{Binding FilterPanels}" ItemTemplate="{StaticResource PanelPlaceholderTemplate}" />

            <ItemsControl Grid.Column="1"
                          Margin="16,0"
                          ItemsSource="{Binding ListPanels}"
                          ItemTemplate="{StaticResource PanelPlaceholderTemplate}" />

            <ItemsControl Grid.Column="2"
                          ItemsSource="{Binding DetailPanels}"
                          ItemTemplate="{StaticResource PanelPlaceholderTemplate}" />
        </Grid>
    </Grid>
</UserControl>

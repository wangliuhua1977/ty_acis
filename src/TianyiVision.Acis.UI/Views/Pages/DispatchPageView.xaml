<UserControl x:Class="TianyiVision.Acis.UI.Views.Pages.DispatchPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:state="clr-namespace:TianyiVision.Acis.UI.States">
    <UserControl.Resources>
        <Style x:Key="DispatchFilterChipButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
            <Setter Property="Margin" Value="0,0,10,10" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Theme.SelectionBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.SelectionBorderBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DispatchWorkOrderRowButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Theme.SelectionBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.SelectionBorderBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DispatchStatusChipStyle" TargetType="Border">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Background" Value="{DynamicResource Theme.PanelMutedBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="{x:Static state:DispatchWorkOrderStatus.PendingDispatch}">
                    <Setter Property="Background" Value="{DynamicResource Theme.WarningSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="{x:Static state:DispatchWorkOrderStatus.Dispatched}">
                    <Setter Property="Background" Value="{DynamicResource Theme.AccentSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.AccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="{x:Static state:DispatchRecoveryStatus.Unrecovered}">
                    <Setter Property="Background" Value="{DynamicResource Theme.DangerSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.DangerBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="{x:Static state:DispatchRecoveryStatus.Recovered}">
                    <Setter Property="Background" Value="{DynamicResource Theme.SuccessSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="{x:Static state:DispatchMethod.Automatic}">
                    <Setter Property="Background" Value="{DynamicResource Theme.InspectionActiveSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.InspectionActiveBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="{x:Static state:DispatchMethod.Manual}">
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.PanelBorderStrongBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="{Binding Title}" />
                <TextBlock Margin="0,10,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding Description}" />
            </StackPanel>

            <Border Grid.Column="1" Style="{StaticResource MutedPanelStyle}" Margin="16,0,0,0" Padding="14,12">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding MergeTitle}" />
                    <TextBlock Margin="0,8,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding WorkspaceFeedback}" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="282" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="390" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PrimaryPanelStyle}" Margin="0,0,16,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding FilterTitle}" />
                        <TextBlock Margin="0,8,0,16" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding FilterDescription}" />

                        <ItemsControl ItemsSource="{Binding FilterState.QuickFilters}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type state:DispatchFilterOptionState}">
                                    <Button Style="{StaticResource DispatchFilterChipButtonStyle}"
                                            Command="{Binding DataContext.SelectQuickFilterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="{Binding Label}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Margin="0,10,0,6" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding FilterGroupLabel}" />
                        <ComboBox ItemsSource="{Binding FilterState.GroupOptions}" DisplayMemberPath="Label" SelectedItem="{Binding FilterState.SelectedGroupOption, Mode=TwoWay}" />
                        <TextBlock Margin="0,14,0,6" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding FilterUnitLabel}" />
                        <ComboBox ItemsSource="{Binding FilterState.UnitOptions}" DisplayMemberPath="Label" SelectedItem="{Binding FilterState.SelectedUnitOption, Mode=TwoWay}" />
                        <TextBlock Margin="0,14,0,6" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding FilterMaintainerLabel}" />
                        <ComboBox ItemsSource="{Binding FilterState.MaintainerOptions}" DisplayMemberPath="Label" SelectedItem="{Binding FilterState.SelectedMaintainerOption, Mode=TwoWay}" />
                        <TextBlock Margin="0,14,0,6" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding FilterSupervisorLabel}" />
                        <ComboBox ItemsSource="{Binding FilterState.SupervisorOptions}" DisplayMemberPath="Label" SelectedItem="{Binding FilterState.SelectedSupervisorOption, Mode=TwoWay}" />
                        <TextBlock Margin="0,14,0,6" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding FilterFaultTypeLabel}" />
                        <ComboBox ItemsSource="{Binding FilterState.FaultTypeOptions}" DisplayMemberPath="Label" SelectedItem="{Binding FilterState.SelectedFaultTypeOption, Mode=TwoWay}" />

                        <Border Margin="0,18,0,0" Style="{StaticResource MutedPanelStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding MergeTitle}" />
                                <TextBlock Margin="0,8,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding MergeDescription}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource PrimaryPanelStyle}" Margin="0,0,16,14" Padding="16,14">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding ListTitle}" />
                        <TextBlock Margin="0,8,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding ListDescription}" />
                    </StackPanel>
                </Border>

                <Grid Grid.Row="1">
                    <Border Style="{StaticResource PrimaryPanelStyle}" Margin="0,0,16,0" Visibility="{Binding HasWorkOrders, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.6*" />
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="1.25*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1.3*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding PointNameColumnLabel}" />
                                <TextBlock Grid.Column="1" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding FaultTypeColumnLabel}" />
                                <TextBlock Grid.Column="2" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding HandlingUnitColumnLabel}" />
                                <TextBlock Grid.Column="3" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding MaintainerColumnLabel}" />
                                <TextBlock Grid.Column="4" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding SupervisorColumnLabel}" />
                                <TextBlock Grid.Column="5" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding LatestFaultTimeColumnLabel}" />
                            </Grid>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding FilteredWorkOrders}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type state:DispatchWorkOrderSummaryState}">
                                            <Button Style="{StaticResource DispatchWorkOrderRowButtonStyle}"
                                                    Command="{Binding DataContext.SelectWorkOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Border Padding="14" Background="Transparent" CornerRadius="14">
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="1.6*" />
                                                                <ColumnDefinition Width="1.2*" />
                                                                <ColumnDefinition Width="1.25*" />
                                                                <ColumnDefinition Width="1*" />
                                                                <ColumnDefinition Width="1*" />
                                                                <ColumnDefinition Width="1.3*" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding PointName}" TextWrapping="Wrap" />
                                                                <Border Margin="0,8,0,0"
                                                                        Style="{StaticResource DispatchStatusChipStyle}"
                                                                        Visibility="{Binding IsRepeated, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                    <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding RepeatSummary}" />
                                                                </Border>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="1" Style="{StaticResource FieldValueTextStyle}" Text="{Binding FaultType}" TextWrapping="Wrap" />
                                                            <TextBlock Grid.Column="2" Style="{StaticResource FieldValueTextStyle}" Text="{Binding CurrentHandlingUnit}" TextWrapping="Wrap" />
                                                            <TextBlock Grid.Column="3" Style="{StaticResource FieldValueTextStyle}" Text="{Binding MaintainerName}" TextWrapping="Wrap" />
                                                            <TextBlock Grid.Column="4" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SupervisorName}" TextWrapping="Wrap" />
                                                            <TextBlock Grid.Column="5" Style="{StaticResource FieldValueTextStyle}" Text="{Binding LatestFaultTime}" TextWrapping="Wrap" />
                                                        </Grid>

                                                        <WrapPanel Margin="0,14,0,0">
                                                            <Border Style="{StaticResource DispatchStatusChipStyle}" Tag="{Binding WorkOrderStatus}">
                                                                <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding WorkOrderStatusText}" />
                                                            </Border>
                                                            <Border Style="{StaticResource DispatchStatusChipStyle}" Tag="{Binding RecoveryStatus}">
                                                                <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding RecoveryStatusText}" />
                                                            </Border>
                                                            <Border Style="{StaticResource DispatchStatusChipStyle}" Tag="{Binding DispatchMethod}">
                                                                <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding DispatchMethodText}" />
                                                            </Border>
                                                            <Border Style="{StaticResource DispatchStatusChipStyle}" Visibility="{Binding IsTodayNew, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding DataContext.DispatchQuickFilterTodayNewText, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                            </Border>
                                                        </WrapPanel>
                                                    </StackPanel>
                                                </Border>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource MutedPanelStyle}" Margin="0,0,16,0" Visibility="{Binding HasNoWorkOrders, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding EmptyStateTitle}" />
                            <TextBlock Margin="0,10,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding EmptyStateDescription}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <Grid Grid.Column="2">
                <Border Style="{StaticResource PrimaryPanelStyle}" Visibility="{Binding HasSelectedWorkOrder, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding DetailTitle}" />
                            <TextBlock Margin="0,8,0,14" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding DetailDescription}" />
                            <WrapPanel>
                                <Button Style="{StaticResource PrimaryActionButtonStyle}" Command="{Binding DispatchNowCommand}" Content="{Binding DispatchNowText}" />
                                <Button Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding MarkRecoveredCommand}" Content="{Binding MarkRecoveredText}" />
                                <Button Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding OpenResponsibilityEditorCommand}" Content="{Binding EditResponsibilityText}" />
                            </WrapPanel>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" Margin="0,18,0,0" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Style="{StaticResource MutedPanelStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding DetailBasicTitle}" />
                                        <Grid Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="128" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailPointNameLabel}" />
                                            <TextBlock Grid.Column="1" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedWorkOrderDetail.PointName}" />
                                            <TextBlock Grid.Row="1" Margin="0,12,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailFaultTypeLabel}" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedWorkOrderDetail.FaultType}" />
                                            <TextBlock Grid.Row="2" Margin="0,12,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailInspectionGroupLabel}" />
                                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedWorkOrderDetail.InspectionGroupName}" />
                                            <TextBlock Grid.Row="3" Margin="0,12,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailFirstFaultTimeLabel}" />
                                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedWorkOrderDetail.RepeatFault.FirstFaultTime}" />
                                            <TextBlock Grid.Row="4" Margin="0,12,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailLatestFaultTimeLabel}" />
                                            <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedWorkOrderDetail.RepeatFault.LatestFaultTime}" />
                                            <TextBlock Grid.Row="5" Margin="0,12,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailRepeatCountLabel}" />
                                            <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedWorkOrderDetail.RepeatFault.RepeatSummary}" />
                                        </Grid>
                                        <TextBlock Margin="0,16,0,8" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding DetailMapLocationLabel}" />
                                        <Border Style="{StaticResource PrimaryPanelStyle}" Padding="16" Background="{DynamicResource Theme.PanelMutedBackgroundBrush}">
                                            <TextBlock Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding SelectedWorkOrderDetail.MapLocationPlaceholder}" />
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource MutedPanelStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding DetailResponsibilityTitle}" />
                                        <Grid Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="128" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailCurrentHandlingUnitLabel}" />
                                            <TextBlock Grid.Column="1" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedWorkOrderDetail.Responsibility.CurrentHandlingUnit}" />
                                            <TextBlock Grid.Row="1" Margin="0,12,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailMaintainerLabel}" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedWorkOrderDetail.Responsibility.MaintainerName}" />
                                            <TextBlock Grid.Row="2" Margin="0,12,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailMaintainerPhoneLabel}" />
                                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedWorkOrderDetail.Responsibility.MaintainerPhone}" />
                                            <TextBlock Grid.Row="3" Margin="0,12,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailSupervisorLabel}" />
                                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedWorkOrderDetail.Responsibility.SupervisorName}" />
                                            <TextBlock Grid.Row="4" Margin="0,12,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailSupervisorPhoneLabel}" />
                                            <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedWorkOrderDetail.Responsibility.SupervisorPhone}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource MutedPanelStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding DetailNotificationTitle}" />
                                        <Grid Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="128" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailFaultNotificationTimeLabel}" />
                                            <TextBlock Grid.Column="1" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedWorkOrderDetail.NotificationRecord.FaultNotificationSentAt}" />
                                            <TextBlock Grid.Row="1" Margin="0,12,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailFaultNotificationStatusLabel}" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedWorkOrderDetail.NotificationRecord.FaultNotificationStatus}" />
                                            <TextBlock Grid.Row="2" Margin="0,12,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailRecoveryNotificationTimeLabel}" />
                                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedWorkOrderDetail.NotificationRecord.RecoveryNotificationSentAt}" />
                                            <TextBlock Grid.Row="3" Margin="0,12,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailRecoveryNotificationStatusLabel}" />
                                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedWorkOrderDetail.NotificationRecord.RecoveryNotificationStatus}" />
                                        </Grid>
                                        <TextBlock Margin="0,16,0,10" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding TimelineTitle}" />
                                        <ItemsControl ItemsSource="{Binding SelectedWorkOrderDetail.NotificationRecord.TimelineEntries}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type state:DispatchNotificationEntryState}">
                                                    <Border Style="{StaticResource PrimaryPanelStyle}" Margin="0,0,0,10" Padding="12">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                                                <TextBlock Margin="0,6,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding Summary}" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" Margin="18,0,0,0">
                                                                <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding StatusText}" />
                                                                <TextBlock Margin="0,6,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding SentAt}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource MutedPanelStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding DetailEvidenceTitle}" />
                                        <TextBlock Margin="0,8,0,14" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding EvidenceDescription}" />
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding DetailScreenshotLabel}" />
                                        <Border Margin="0,10,0,0" Style="{StaticResource PrimaryPanelStyle}" Padding="20" Background="{DynamicResource Theme.PanelBackgroundBrush}">
                                            <StackPanel>
                                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding SelectedWorkOrderDetail.ScreenshotTitle}" />
                                                <TextBlock Margin="0,8,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding SelectedWorkOrderDetail.ScreenshotSubtitle}" />
                                            </StackPanel>
                                        </Border>
                                        <Grid Margin="0,16,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="128" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailFaultSummaryLabel}" />
                                            <TextBlock Grid.Column="1" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding SelectedWorkOrderDetail.FaultSummary}" />
                                            <TextBlock Grid.Row="1" Margin="0,12,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailLatestInspectionConclusionLabel}" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedWorkOrderDetail.LatestInspectionConclusion}" />
                                            <TextBlock Grid.Row="2" Margin="0,12,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailDispatchPoolEntryLabel}" />
                                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedWorkOrderDetail.DispatchPoolEntryText}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Style="{StaticResource MutedPanelStyle}" Visibility="{Binding HasNoSelectedWorkOrder, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding EmptyStateTitle}" />
                        <TextBlock Margin="0,10,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding EmptyStateDescription}" />
                    </StackPanel>
                </Border>

                <Grid Background="{DynamicResource Theme.WindowBackgroundBrush}" Visibility="{Binding IsResponsibilityEditorOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border Width="320"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Style="{StaticResource PrimaryPanelStyle}"
                            Margin="16">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding ResponsibilityEditorTitle}" />
                            <TextBlock Margin="0,8,0,14" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding ResponsibilityEditorDescription}" />
                            <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding DetailCurrentHandlingUnitLabel}" />
                            <TextBox Margin="0,8,0,0" Text="{Binding ResponsibilityEditor.CurrentHandlingUnit, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,14,0,0" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding DetailMaintainerLabel}" />
                            <TextBox Margin="0,8,0,0" Text="{Binding ResponsibilityEditor.MaintainerName, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,14,0,0" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding DetailMaintainerPhoneLabel}" />
                            <TextBox Margin="0,8,0,0" Text="{Binding ResponsibilityEditor.MaintainerPhone, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,14,0,0" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding DetailSupervisorLabel}" />
                            <TextBox Margin="0,8,0,0" Text="{Binding ResponsibilityEditor.SupervisorName, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,14,0,0" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding DetailSupervisorPhoneLabel}" />
                            <TextBox Margin="0,8,0,0" Text="{Binding ResponsibilityEditor.SupervisorPhone, UpdateSourceTrigger=PropertyChanged}" />
                            <WrapPanel Margin="0,18,0,0">
                                <Button Style="{StaticResource PrimaryActionButtonStyle}" Command="{Binding SaveResponsibilityCommand}" Content="{Binding SaveResponsibilityText}" />
                                <Button Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding CancelResponsibilityCommand}" Content="{Binding CancelResponsibilityText}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

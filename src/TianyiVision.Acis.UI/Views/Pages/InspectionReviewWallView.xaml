<UserControl x:Class="TianyiVision.Acis.UI.Views.Pages.InspectionReviewWallView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:state="clr-namespace:TianyiVision.Acis.UI.States">
    <UserControl.Resources>
        <Style x:Key="ReviewSummaryPanelStyle" TargetType="Border" BasedOn="{StaticResource PrimaryPanelStyle}">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="ReviewFilterChipButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
            <Setter Property="Margin" Value="0,0,10,10" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Theme.SelectionBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.SelectionBorderBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ReviewComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource Theme.PanelMutedBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,8,12,0" />
            <Setter Property="MinWidth" Value="180" />
        </Style>

        <Style x:Key="ReviewCardButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
            <Setter Property="Width" Value="278" />
            <Setter Property="Margin" Value="0,0,16,16" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFault}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Theme.DangerSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.DangerBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsReviewed}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Theme.SelectionBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.SelectionBorderBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ReviewStatusTagStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource Theme.WarningSoftBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.WarningBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsReviewed}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Theme.SuccessSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.SuccessBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ReviewScreenshotStyle" TargetType="Border">
            <Setter Property="Height" Value="144" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Background" Value="{DynamicResource Theme.InspectionActiveSoftBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.InspectionActiveBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFault}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Theme.DangerSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,20">
            <TextBlock Style="{StaticResource AccentTextStyle}" Text="{Binding ReviewWallBadge}" />
            <TextBlock Margin="0,10,0,0" Style="{StaticResource PageTitleTextStyle}" Text="{Binding ReviewWallTitle}" />
            <TextBlock Margin="0,10,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding ReviewWallDescription}" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource ReviewSummaryPanelStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="300" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding ReviewWallTitle}" />
                        <TextBlock Margin="0,8,0,16" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding ReviewSummaryDescription}" />
                        <UniformGrid Columns="4">
                            <StackPanel Margin="0,0,20,12">
                                <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding CurrentGroupLabel}" />
                                <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding ReviewTaskSummary.GroupName}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,20,12">
                                <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding RunSummaryStartedAtLabel}" />
                                <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding ReviewTaskSummary.StartedAt}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,20,12">
                                <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding ReviewTaskFinishedAtLabel}" />
                                <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding ReviewTaskSummary.FinishedAt}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,20,12">
                                <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding RunSummaryTotalPointsLabel}" />
                                <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding ReviewTaskSummary.TotalPoints}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,20,0">
                                <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding RunSummaryNormalLabel}" />
                                <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding ReviewTaskSummary.NormalCount}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,20,0">
                                <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding RunSummaryFaultLabel}" />
                                <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding ReviewTaskSummary.FaultCount}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,20,0">
                                <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding ReviewTaskReviewStatusLabel}" />
                                <Border Margin="0,8,0,0" DataContext="{Binding ReviewTaskSummary}" Style="{StaticResource ReviewStatusTagStyle}">
                                    <TextBlock Style="{StaticResource FieldValueTextStyle}" Text="{Binding ReviewStatusText}" />
                                </Border>
                            </StackPanel>
                            <StackPanel Margin="0,0,20,0">
                                <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding ReviewTaskReviewedCountLabel}" />
                                <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding ReviewTaskSummary.ReviewedCount}" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <Button Style="{StaticResource PrimaryActionButtonStyle}" Command="{Binding ConfirmReviewCompletedCommand}" Content="{Binding ReviewConfirmTaskText}" />
                        <Button Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding ReturnToInspectionWorkspaceCommand}" Content="{Binding ReviewBackToInspectionText}" />
                        <Border Margin="0,12,0,0" Style="{StaticResource MutedPanelStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding ReviewTaskTransitionHintLabel}" />
                                <TextBlock Margin="0,10,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding ReviewTaskSummary.TransitionHint}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="360" />
                </Grid.ColumnDefinitions>

                <Grid Margin="0,0,18,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource ReviewSummaryPanelStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding ReviewFilterTitle}" />
                            <TextBlock Margin="0,8,0,16" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding ReviewFilterDescription}" />
                            <ItemsControl ItemsSource="{Binding ReviewFilter.QuickFilters}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource ReviewFilterChipButtonStyle}"
                                                Command="{Binding DataContext.SelectReviewQuickFilterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="{Binding Label}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <WrapPanel Margin="0,8,0,0">
                                <StackPanel Margin="0,0,14,0">
                                    <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding ReviewFilterUnitLabel}" />
                                    <ComboBox Style="{StaticResource ReviewComboBoxStyle}"
                                              ItemsSource="{Binding ReviewFilter.UnitOptions}"
                                              SelectedItem="{Binding ReviewFilter.SelectedUnit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding ReviewFilterFaultTypeLabel}" />
                                    <ComboBox Style="{StaticResource ReviewComboBoxStyle}"
                                              ItemsSource="{Binding ReviewFilter.FaultTypeOptions}"
                                              SelectedItem="{Binding ReviewFilter.SelectedFaultType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource ReviewSummaryPanelStyle}" Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding ReviewWallSectionDescription}" />
                            <ScrollViewer Grid.Row="1" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding FilteredReviewCards}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type state:InspectionReviewCardState}">
                                            <Button Style="{StaticResource ReviewCardButtonStyle}"
                                                    Command="{Binding DataContext.SelectReviewCardCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Border Padding="16" Background="Transparent" CornerRadius="16">
                                                    <StackPanel>
                                                        <DockPanel>
                                                            <StackPanel DockPanel.Dock="Left">
                                                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding PointName}" />
                                                                <TextBlock Margin="0,6,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding UnitName}" />
                                                            </StackPanel>
                                                            <Border DockPanel.Dock="Right" Style="{StaticResource ReviewStatusTagStyle}">
                                                                <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding ReviewStatusText}" />
                                                            </Border>
                                                        </DockPanel>

                                                        <Border Margin="0,14,0,0" Style="{StaticResource ReviewScreenshotStyle}">
                                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                <TextBlock Style="{StaticResource AccentTextStyle}" Text="{Binding InspectionResult}" />
                                                                <TextBlock Margin="0,16,0,0" FontSize="20" FontWeight="SemiBold" Text="{Binding ScreenshotTitle}" />
                                                            </StackPanel>
                                                        </Border>

                                                        <TextBlock Margin="0,14,0,0" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding InspectionResult}" />
                                                        <TextBlock Margin="0,8,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding FaultDescription}" />

                                                        <Grid Margin="0,14,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding DataContext.DispatchEntryLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                                <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding DispatchPoolEntry}" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding DataContext.DetailFaultTypeLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                                <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding FaultType}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <Border Style="{StaticResource ReviewSummaryPanelStyle}" Margin="0">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding DetailsSectionTitle}" />
                            <TextBlock Margin="0,8,0,16" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding ReviewDetailDescription}" />

                            <Border Style="{StaticResource MutedPanelStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding DetailBasicTitle}" />
                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailPointNameLabel}" />
                                        <TextBlock Grid.Column="1" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedReviewDetail.PointName}" />
                                        <TextBlock Grid.Row="1" Margin="0,12,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailUnitLabel}" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedReviewDetail.UnitName}" />
                                        <TextBlock Grid.Row="2" Margin="0,12,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding ReviewDetailReviewStatusLabel}" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedReviewDetail.ReviewStatusText}" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource MutedPanelStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding DetailStatusTitle}" />
                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="{Binding ReviewDetailResultLabel}" />
                                        <TextBlock Grid.Column="1" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedReviewDetail.InspectionResult}" />
                                        <TextBlock Grid.Row="1" Margin="0,12,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailOnlineLabel}" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedReviewDetail.OnlineStatus}" />
                                        <TextBlock Grid.Row="2" Margin="0,12,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailPlaybackLabel}" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedReviewDetail.PlaybackStatus}" />
                                        <TextBlock Grid.Row="3" Margin="0,12,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailImageLabel}" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedReviewDetail.ImageStatus}" />
                                        <TextBlock Grid.Row="4" Margin="0,12,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailFaultTypeLabel}" />
                                        <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedReviewDetail.FaultType}" />
                                    </Grid>
                                    <TextBlock Margin="0,16,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailFaultNoteLabel}" />
                                    <TextBlock Margin="0,8,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding SelectedReviewDetail.FaultDescription}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource MutedPanelStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding ReviewDetailScreenshotLabel}" />
                                    <Border Margin="0,14,0,0" Height="220" DataContext="{Binding SelectedReviewDetail}" Style="{StaticResource ReviewScreenshotStyle}">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Style="{StaticResource AccentTextStyle}" Text="{Binding InspectionResult}" />
                                            <TextBlock Margin="0,18,0,0" FontSize="24" FontWeight="SemiBold" Text="{Binding ScreenshotTitle}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource MutedPanelStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding HistorySectionTitle}" />
                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DispatchEntryLabel}" />
                                        <TextBlock Grid.Column="1" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedReviewDetail.DispatchPoolEntry}" />
                                        <TextBlock Grid.Row="1" Margin="0,12,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding LastFaultLabel}" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedReviewDetail.LastFaultTime}" />
                                        <TextBlock Grid.Row="2" Margin="0,12,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding LastConclusionLabel}" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedReviewDetail.LastInspectionConclusion}" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource MutedPanelStyle}" Margin="0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding ReviewDetailReviewNoteLabel}" />
                                    <TextBlock Margin="0,10,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding SelectedReviewDetail.ReviewNotePlaceholder}" />
                                    <TextBlock Margin="0,14,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding ReviewTaskSummary.TransitionHint}" />
                                    <Button Margin="0,16,0,0"
                                            Style="{StaticResource PrimaryActionButtonStyle}"
                                            Command="{Binding MarkSelectedReviewCommand}"
                                            Content="{Binding ReviewMarkReviewedText}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

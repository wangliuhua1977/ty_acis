<UserControl x:Class="TianyiVision.Acis.UI.Views.Pages.SettingsPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,20">
            <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="{Binding Title}" />
            <TextBlock Margin="0,10,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding Description}" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PrimaryPanelStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource MetricTitleTextStyle}" Text="{Binding ActiveThemeLabel}" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Theme.TextPrimaryBrush}"
                               Text="{Binding ActiveThemeName}" />
                    <TextBlock Margin="0,18,0,0" Style="{StaticResource MetricTitleTextStyle}" Text="{Binding AvailableThemesLabel}" />
                    <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding ThemeNames}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="10"
                                        Background="{DynamicResource Theme.PanelMutedBackgroundBrush}"
                                        BorderBrush="{DynamicResource Theme.PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <TextBlock Foreground="{DynamicResource Theme.TextPrimaryBrush}" Text="{Binding}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Margin="12,0,0,0" Style="{StaticResource PrimaryPanelStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource MetricTitleTextStyle}" Text="{Binding ActiveTerminologyLabel}" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Theme.TextPrimaryBrush}"
                               Text="{Binding ActiveTerminologyName}" />
                    <TextBlock Margin="0,18,0,0" Style="{StaticResource MetricTitleTextStyle}" Text="{Binding AvailableTerminologiesLabel}" />
                    <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding TerminologyNames}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="10"
                                        Background="{DynamicResource Theme.PanelMutedBackgroundBrush}"
                                        BorderBrush="{DynamicResource Theme.PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <TextBlock Foreground="{DynamicResource Theme.TextPrimaryBrush}" Text="{Binding}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>

        <ItemsControl Grid.Row="2" ItemsSource="{Binding Cards}" ItemTemplate="{StaticResource PanelPlaceholderTemplate}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="2" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </Grid>
</UserControl>

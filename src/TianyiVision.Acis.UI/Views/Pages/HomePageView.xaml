<UserControl x:Class="TianyiVision.Acis.UI.Views.Pages.HomePageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:state="clr-namespace:TianyiVision.Acis.UI.States">
    <UserControl.Resources>
        <Style x:Key="HomeStatusMetricButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Theme.SelectionBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.SelectionBorderBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HomeSectionCardStyle" TargetType="Border" BasedOn="{StaticResource PrimaryPanelStyle}">
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="HomeFaultButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Theme.DangerSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HomeMapPointButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="92" />
            <Setter Property="Height" Value="92" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Width="92" Height="92" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform />
                            </Grid.RenderTransform>
                            <Ellipse x:Name="PulseRing" Width="72" Height="72" Fill="{DynamicResource Theme.InspectionActiveSoftBrush}" Opacity="0" />
                            <Ellipse x:Name="FaultRing" Width="76" Height="76" Fill="{DynamicResource Theme.DangerSoftBrush}" Opacity="0" />
                            <Border x:Name="CoreBorder"
                                    Width="50"
                                    Height="50"
                                    CornerRadius="25"
                                    Background="{DynamicResource Theme.AccentSoftBrush}"
                                    BorderBrush="{DynamicResource Theme.PanelBorderStrongBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Top"
                                    HorizontalAlignment="Center">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="8"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Text="{Binding Name}" />
                            </Border>
                            <Border x:Name="SelectionTag"
                                    Width="16"
                                    Height="16"
                                    CornerRadius="8"
                                    Background="{DynamicResource Theme.AccentBrush}"
                                    BorderBrush="{DynamicResource Theme.TextPrimaryBrush}"
                                    BorderThickness="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,10,10,0"
                                    Visibility="Collapsed" />
                            <TextBlock Margin="0,62,0,0"
                                       Width="90"
                                       HorizontalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource Theme.TextPrimaryBrush}"
                                       Text="{Binding Name}"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding Kind}" Value="{x:Static state:HomeMapPointKind.Normal}">
                                <Setter TargetName="CoreBorder" Property="Background" Value="{DynamicResource Theme.SuccessSoftBrush}" />
                                <Setter TargetName="CoreBorder" Property="BorderBrush" Value="{DynamicResource Theme.SuccessBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Kind}" Value="{x:Static state:HomeMapPointKind.Fault}">
                                <Setter TargetName="CoreBorder" Property="Background" Value="{DynamicResource Theme.DangerSoftBrush}" />
                                <Setter TargetName="CoreBorder" Property="BorderBrush" Value="{DynamicResource Theme.DangerBrush}" />
                                <Setter TargetName="FaultRing" Property="Opacity" Value="0.65" />
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetName="FaultRing" Storyboard.TargetProperty="Opacity" From="0.25" To="0.95" Duration="0:0:0.75" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Kind}" Value="{x:Static state:HomeMapPointKind.Key}">
                                <Setter TargetName="CoreBorder" Property="Background" Value="{DynamicResource Theme.WarningSoftBrush}" />
                                <Setter TargetName="CoreBorder" Property="BorderBrush" Value="{DynamicResource Theme.WarningBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Kind}" Value="{x:Static state:HomeMapPointKind.Inspecting}">
                                <Setter TargetName="CoreBorder" Property="Background" Value="{DynamicResource Theme.InspectionActiveSoftBrush}" />
                                <Setter TargetName="CoreBorder" Property="BorderBrush" Value="{DynamicResource Theme.InspectionActiveBrush}" />
                                <Setter TargetName="PulseRing" Property="Opacity" Value="0.75" />
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="PulseRing" Storyboard.TargetProperty="Opacity" From="0.25" To="0.8" Duration="0:0:0.8" AutoReverse="True" />
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="1" To="1.05" Duration="0:0:0.8" AutoReverse="True" />
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="1" To="1.05" Duration="0:0:0.8" AutoReverse="True" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="CoreBorder" Property="BorderThickness" Value="2" />
                                <Setter TargetName="SelectionTag" Property="Visibility" Value="Visible" />
                                <Setter TargetName="CoreBorder" Property="Width" Value="54" />
                                <Setter TargetName="CoreBorder" Property="Height" Value="54" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,14">
            <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="{Binding Title}" />
            <TextBlock Margin="0,10,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding Description}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource HomeSectionCardStyle}" Padding="14" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="280" />
                </Grid.ColumnDefinitions>

                <ItemsControl ItemsSource="{Binding StatusMetrics}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" Columns="5" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type state:HomeStatusMetricState}">
                            <Button Style="{StaticResource HomeStatusMetricButtonStyle}"
                                    Command="{Binding DataContext.SelectStatusMetricCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetricTitleTextStyle}" Text="{Binding Title}" />
                                    <TextBlock Margin="0,8,0,0" FontSize="22" FontWeight="SemiBold" Text="{Binding Value}" />
                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding Hint}" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Grid.Column="1" Margin="16,0,0,0" Background="{DynamicResource Theme.PanelMutedBackgroundBrush}" BorderBrush="{DynamicResource Theme.PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricTitleTextStyle}" Text="{Binding StatusBarDescription}" />
                        <TextBlock Margin="0,8,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding StatusFeedback}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*" />
                <ColumnDefinition Width="4.9*" />
                <ColumnDefinition Width="1.15*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,16,0">
                    <Border Style="{StaticResource HomeSectionCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding LeftSummaryTitle}" />
                            <TextBlock Margin="0,8,0,16" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding LeftSummaryDescription}" />
                            <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding CurrentGroupLabel}" />
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding CurrentGroupSummary}" />
                            <TextBlock Margin="0,16,0,0" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding ExecutionProgressLabel}" />
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding ExecutionProgress}" />
                            <ProgressBar Margin="0,12,0,0" Height="8" Maximum="12" Value="8" />
                            <TextBlock Margin="0,16,0,0" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding PendingReviewLabel}" />
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding PendingReviewSummary}" />
                            <TextBlock Margin="0,16,0,0" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding PendingDispatchLabel}" />
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding PendingDispatchSummary}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource HomeSectionCardStyle}" Margin="0">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding RecentFaultsTitle}" />
                            <TextBlock Margin="0,8,0,16" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding RecentFaultsDescription}" />
                            <ItemsControl ItemsSource="{Binding RecentFaults}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type state:HomeRecentFaultState}">
                                        <Button Style="{StaticResource HomeFaultButtonStyle}"
                                                Command="{Binding DataContext.SelectRecentFaultCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding PointName}" />
                                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding FaultType}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding DataContext.RecentFaultTimeLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding LatestFaultTime}" />
                                                </StackPanel>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="1" Style="{StaticResource PrimaryPanelStyle}" Padding="14" Margin="0,0,16,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Style="{StaticResource AccentTextStyle}" Text="{Binding MapStageBadge}" />
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource SectionTitleTextStyle}" Text="{Binding MapStageTitle}" />
                            <TextBlock Margin="0,8,0,0" Width="420" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding MapStageDescription}" />
                        </StackPanel>
                        <Border DockPanel.Dock="Right"
                                HorizontalAlignment="Right"
                                Padding="12,8"
                                Background="{DynamicResource Theme.PanelMutedBackgroundBrush}"
                                BorderBrush="{DynamicResource Theme.PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12">
                            <TextBlock Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding MapStageHint}" Width="260" />
                        </Border>
                    </DockPanel>

                    <Border Grid.Row="1"
                            Margin="0,16,0,14"
                            Background="{DynamicResource Theme.WorkbenchBackgroundBrush}"
                            BorderBrush="{DynamicResource Theme.PanelBorderStrongBrush}"
                            BorderThickness="1"
                            CornerRadius="24"
                            Padding="12">
                        <Grid ClipToBounds="True">
                            <Canvas>
                                <Line X1="40" Y1="80" X2="1180" Y2="80" Stroke="{DynamicResource Theme.MapGridOverlayBrush}" StrokeThickness="1" />
                                <Line X1="40" Y1="190" X2="1180" Y2="190" Stroke="{DynamicResource Theme.MapGridOverlayBrush}" StrokeThickness="1" />
                                <Line X1="40" Y1="300" X2="1180" Y2="300" Stroke="{DynamicResource Theme.MapGridOverlayBrush}" StrokeThickness="1" />
                                <Line X1="40" Y1="410" X2="1180" Y2="410" Stroke="{DynamicResource Theme.MapGridOverlayBrush}" StrokeThickness="1" />
                                <Line X1="120" Y1="20" X2="120" Y2="470" Stroke="{DynamicResource Theme.MapGridOverlayBrush}" StrokeThickness="1" />
                                <Line X1="320" Y1="20" X2="320" Y2="470" Stroke="{DynamicResource Theme.MapGridOverlayBrush}" StrokeThickness="1" />
                                <Line X1="520" Y1="20" X2="520" Y2="470" Stroke="{DynamicResource Theme.MapGridOverlayBrush}" StrokeThickness="1" />
                                <Line X1="720" Y1="20" X2="720" Y2="470" Stroke="{DynamicResource Theme.MapGridOverlayBrush}" StrokeThickness="1" />
                                <Line X1="920" Y1="20" X2="920" Y2="470" Stroke="{DynamicResource Theme.MapGridOverlayBrush}" StrokeThickness="1" />
                                <Path Stroke="{DynamicResource Theme.AccentSecondaryBrush}" StrokeThickness="2" Opacity="0.45" Data="M 70,340 C 220,210 360,260 520,170 S 820,150 980,240 1090,300 1160,280" />
                                <Path Stroke="{DynamicResource Theme.PanelBorderStrongBrush}" StrokeThickness="2" Opacity="0.40" Data="M 110,140 C 250,290 380,300 560,360 720,410 940,360 1110,180" />
                                <Path Stroke="{DynamicResource Theme.AccentBrush}" StrokeThickness="3" Opacity="0.35" Data="M 200,80 C 310,110 420,120 560,130 690,145 870,160 1060,110" />
                            </Canvas>

                            <ItemsControl ItemsSource="{Binding MapPoints}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}" />
                                        <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type state:HomeMapPointState}">
                                        <Button Style="{StaticResource HomeMapPointButtonStyle}"
                                                Command="{Binding DataContext.SelectMapPointCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="{Binding Name}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <WrapPanel Grid.Row="2">
                        <Border Style="{StaticResource MutedPanelStyle}" Padding="12,8" Margin="0,0,10,0"><TextBlock Style="{StaticResource FieldValueTextStyle}" Text="{Binding LegendFaultText}" /></Border>
                        <Border Style="{StaticResource MutedPanelStyle}" Padding="12,8" Margin="0,0,10,0"><TextBlock Style="{StaticResource FieldValueTextStyle}" Text="{Binding LegendNormalText}" /></Border>
                        <Border Style="{StaticResource MutedPanelStyle}" Padding="12,8" Margin="0,0,10,0"><TextBlock Style="{StaticResource FieldValueTextStyle}" Text="{Binding LegendKeyText}" /></Border>
                        <Border Style="{StaticResource MutedPanelStyle}" Padding="12,8"><TextBlock Style="{StaticResource FieldValueTextStyle}" Text="{Binding LegendInspectingText}" /></Border>
                    </WrapPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource HomeSectionCardStyle}" Margin="0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding RightSummaryTitle}" />
                    <TextBlock Margin="0,8,0,16" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding RightSummaryDescription}" />

                    <Border Height="160"
                            Background="{DynamicResource Theme.InspectionActiveSoftBrush}"
                            BorderBrush="{DynamicResource Theme.InspectionActiveBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="16">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Style="{StaticResource AccentTextStyle}" Text="{Binding SelectedPointSummary.StatusText}" />
                            <TextBlock Margin="0,16,0,0" FontSize="22" FontWeight="SemiBold" Text="{Binding SelectedPointSummary.PointName}" TextAlignment="Center" />
                            <TextBlock Margin="0,12,0,0" Width="220" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding SelectedPointSummary.UnitName}" TextAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="96" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="{Binding SelectedPointStatusLabel}" />
                        <TextBlock Grid.Column="1" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedPointSummary.StatusText}" />
                        <TextBlock Grid.Row="1" Margin="0,12,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding SelectedPointFaultTypeLabel}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedPointSummary.FaultType}" />
                        <TextBlock Grid.Row="2" Margin="0,12,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding SelectedPointSummaryLabel}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding SelectedPointSummary.Summary}" />
                    </Grid>

                    <Border Margin="0,18,0,0" Style="{StaticResource MutedPanelStyle}" Padding="14">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding SelectedPointActionLabel}" />
                            <TextBlock Margin="0,10,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding SelectedPointSummary.ActionHint}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

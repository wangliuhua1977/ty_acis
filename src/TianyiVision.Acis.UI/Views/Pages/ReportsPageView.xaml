<UserControl x:Class="TianyiVision.Acis.UI.Views.Pages.ReportsPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:state="clr-namespace:TianyiVision.Acis.UI.States">
    <UserControl.Resources>
        <Style x:Key="ReportMetricButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,14,14" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Theme.SelectionBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.SelectionBorderBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ReportTabButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Padding" Value="14,8" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Theme.SelectionBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.SelectionBorderBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ReportExportButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Theme.AccentSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="{Binding Title}" />
                    <TextBlock Margin="0,10,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding Description}" />
                </StackPanel>
                <Border Grid.Column="1" Style="{StaticResource MutedPanelStyle}" Margin="16,0,0,0" Padding="14,12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding ExportTitle}" />
                        <TextBlock Margin="0,8,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding ExportDescription}" />
                        <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding ExportActions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type state:ReportExportActionState}">
                                    <Button Style="{StaticResource ReportExportButtonStyle}"
                                            Command="{Binding DataContext.TriggerExportCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                            <TextBlock Margin="0,6,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding Description}" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border Margin="0,8,0,0" Style="{StaticResource PrimaryPanelStyle}" Padding="12">
                            <TextBlock Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding WorkspaceFeedback}" />
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="1" Style="{StaticResource PrimaryPanelStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding FilterTitle}" />
                    <TextBlock Margin="0,8,0,16" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding FilterDescription}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding FilterTimeLabel}" />
                            <ComboBox Margin="0,8,0,0" ItemsSource="{Binding FilterState.TimeRangeOptions}" DisplayMemberPath="Label" SelectedItem="{Binding FilterState.SelectedTimeRangeOption, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding FilterGroupLabel}" />
                            <ComboBox Margin="0,8,0,0" ItemsSource="{Binding FilterState.GroupOptions}" DisplayMemberPath="Label" SelectedItem="{Binding FilterState.SelectedGroupOption, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="0,0,12,0">
                            <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding FilterUnitLabel}" />
                            <ComboBox Margin="0,8,0,0" ItemsSource="{Binding FilterState.UnitOptions}" DisplayMemberPath="Label" SelectedItem="{Binding FilterState.SelectedUnitOption, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Margin="0,0,12,0">
                            <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding FilterFaultTypeLabel}" />
                            <ComboBox Margin="0,8,0,0" ItemsSource="{Binding FilterState.FaultTypeOptions}" DisplayMemberPath="Label" SelectedItem="{Binding FilterState.SelectedFaultTypeOption, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <Button Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding ApplyFiltersCommand}" Content="{Binding FilterApplyText}" />
                            <Button Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding ResetFiltersCommand}" Content="{Binding FilterResetText}" />
                        </StackPanel>
                    </Grid>
                    <Border Margin="0,14,0,0" Style="{StaticResource MutedPanelStyle}" Padding="12" Visibility="{Binding IsCustomRangeSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding FilterCustomPlaceholderText}" />
                    </Border>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="2" Margin="0,0,0,16">
                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding SummaryTitle}" />
                <TextBlock Margin="0,8,0,12" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding SummaryDescription}" />
                <ItemsControl ItemsSource="{Binding MetricCards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type state:ReportMetricSummaryState}">
                            <Button Style="{StaticResource ReportMetricButtonStyle}"
                                    Command="{Binding DataContext.SelectMetricCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <Border Padding="18" Background="Transparent" CornerRadius="18">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MetricTitleTextStyle}" Text="{Binding Title}" />
                                        <TextBlock Margin="0,10,0,6" Style="{StaticResource MetricValueTextStyle}" Text="{Binding Value}" />
                                        <TextBlock Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding Description}" />
                                    </StackPanel>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,0,0,16">
                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding ChartsTitle}" />
                <TextBlock Margin="0,8,0,12" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding ChartsDescription}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource PrimaryPanelStyle}" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding FaultTrendChart.Title}" />
                            <TextBlock Margin="0,8,0,10" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding FaultTrendChart.Description}" />
                            <Border Style="{StaticResource MutedPanelStyle}" Padding="10,6">
                                <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding FaultTrendChart.PrimaryLegend}" />
                            </Border>
                            <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding FaultTrendChart.TrendPoints}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type state:ReportTrendPointState}">
                                        <Grid Height="180" Margin="0,0,10,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <StackPanel VerticalAlignment="Bottom">
                                                <TextBlock HorizontalAlignment="Center" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding ValueText}" />
                                                <Border Margin="0,8,0,0" Width="28" Height="{Binding VisualHeight}" HorizontalAlignment="Center" Background="{DynamicResource Theme.DangerBrush}" CornerRadius="12,12,4,4" />
                                            </StackPanel>
                                            <TextBlock Grid.Row="1" Margin="0,10,0,0" HorizontalAlignment="Center" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding Label}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Margin="0,10,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding FaultTrendChart.FooterText}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource PrimaryPanelStyle}" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding FaultTypeChart.Title}" />
                            <TextBlock Margin="0,8,0,10" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding FaultTypeChart.Description}" />
                            <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding FaultTypeChart.DistributionPoints}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type state:ReportDistributionPointState}">
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock VerticalAlignment="Center" Style="{StaticResource FieldValueTextStyle}" Text="{Binding Label}" />
                                            <Grid Grid.Column="1" Margin="14,0,14,0" Height="16" VerticalAlignment="Center">
                                                <Border Background="{DynamicResource Theme.PanelMutedBackgroundBrush}" CornerRadius="8" />
                                                <Border Width="{Binding VisualWidth}" HorizontalAlignment="Left" Background="{DynamicResource Theme.WarningBrush}" CornerRadius="8" />
                                            </Grid>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock HorizontalAlignment="Right" Style="{StaticResource FieldValueTextStyle}" Text="{Binding ValueText}" />
                                                <TextBlock HorizontalAlignment="Right" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding ShareText}" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Margin="0,10,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding FaultTypeChart.FooterText}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource PrimaryPanelStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding DispatchRecoveryChart.Title}" />
                            <TextBlock Margin="0,8,0,10" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding DispatchRecoveryChart.Description}" />
                            <WrapPanel>
                                <Border Style="{StaticResource MutedPanelStyle}" Padding="10,6" Margin="0,0,10,0">
                                    <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding DispatchRecoveryChart.PrimaryLegend}" />
                                </Border>
                                <Border Style="{StaticResource MutedPanelStyle}" Padding="10,6">
                                    <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding DispatchRecoveryChart.SecondaryLegend}" />
                                </Border>
                            </WrapPanel>
                            <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding DispatchRecoveryChart.DualTrendPoints}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type state:ReportDualTrendPointState}">
                                        <Grid Height="190" Margin="0,0,10,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <StackPanel VerticalAlignment="Bottom">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <StackPanel Margin="0,0,10,0" VerticalAlignment="Bottom">
                                                        <TextBlock HorizontalAlignment="Center" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding PrimaryValueText}" />
                                                        <Border Margin="0,8,0,0" Width="22" Height="{Binding PrimaryVisualHeight}" Background="{DynamicResource Theme.AccentBrush}" CornerRadius="10,10,4,4" />
                                                    </StackPanel>
                                                    <StackPanel VerticalAlignment="Bottom">
                                                        <TextBlock HorizontalAlignment="Center" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding SecondaryValueText}" />
                                                        <Border Margin="0,8,0,0" Width="22" Height="{Binding SecondaryVisualHeight}" Background="{DynamicResource Theme.SuccessBrush}" CornerRadius="10,10,4,4" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Row="1" Margin="0,10,0,0" HorizontalAlignment="Center" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding Label}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Margin="0,10,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding DispatchRecoveryChart.FooterText}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding DetailsTitle}" />
                    <TextBlock Margin="0,8,0,12" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding DetailsDescription}" />
                    <WrapPanel Margin="0,0,0,12">
                        <ItemsControl ItemsSource="{Binding ReportTabs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type state:ReportTabState}">
                                    <Button Style="{StaticResource ReportTabButtonStyle}"
                                            Command="{Binding DataContext.SelectReportTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="{Binding Label}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </WrapPanel>
                    <TextBlock Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding CurrentRowCountText}" />
                </StackPanel>

                <Grid Grid.Row="1">
                    <Border Style="{StaticResource MutedPanelStyle}" Visibility="{Binding HasNoCurrentRows, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding EmptyStateTitle}" />
                            <TextBlock Margin="0,10,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding EmptyStateDescription}" />
                        </StackPanel>
                    </Border>
                    <Grid Visibility="{Binding HasCurrentRows, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border Style="{StaticResource PrimaryPanelStyle}" Visibility="{Binding IsInspectionExecutionSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.05*" />
                                        <ColumnDefinition Width="1.35*" />
                                        <ColumnDefinition Width="1.15*" />
                                        <ColumnDefinition Width="1.15*" />
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding InspectionDateLabel}" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding InspectionGroupLabel}" />
                                    <TextBlock Grid.Column="2" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding InspectionTaskRunsLabel}" />
                                    <TextBlock Grid.Column="3" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding InspectionPointTotalLabel}" />
                                    <TextBlock Grid.Column="4" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding InspectionNormalLabel}" />
                                    <TextBlock Grid.Column="5" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding InspectionFaultLabel}" />
                                    <TextBlock Grid.Column="6" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding InspectionCompletionRateLabel}" />
                                </Grid>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding FilteredInspectionRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type state:InspectionExecutionReportRowState}">
                                                <Border Style="{StaticResource MutedPanelStyle}" Padding="14" Margin="0,0,0,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="1.05*" />
                                                            <ColumnDefinition Width="1.35*" />
                                                            <ColumnDefinition Width="1.15*" />
                                                            <ColumnDefinition Width="1.15*" />
                                                            <ColumnDefinition Width="1*" />
                                                            <ColumnDefinition Width="1*" />
                                                            <ColumnDefinition Width="1*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Style="{StaticResource FieldValueTextStyle}" Text="{Binding ReportDateText}" />
                                                        <TextBlock Grid.Column="1" Style="{StaticResource FieldValueTextStyle}" Text="{Binding InspectionGroupName}" TextWrapping="Wrap" />
                                                        <TextBlock Grid.Column="2" Style="{StaticResource FieldValueTextStyle}" Text="{Binding DailyTaskRuns}" />
                                                        <TextBlock Grid.Column="3" Style="{StaticResource FieldValueTextStyle}" Text="{Binding TotalPoints}" />
                                                        <TextBlock Grid.Column="4" Style="{StaticResource FieldValueTextStyle}" Text="{Binding NormalPoints}" />
                                                        <TextBlock Grid.Column="5" Style="{StaticResource FieldValueTextStyle}" Text="{Binding FaultPoints}" />
                                                        <TextBlock Grid.Column="6" Style="{StaticResource FieldValueTextStyle}" Text="{Binding CompletionRateText}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource PrimaryPanelStyle}" Visibility="{Binding IsFaultStatisticsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding FaultDateLabel}" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding FaultTotalLabel}" />
                                    <TextBlock Grid.Column="2" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding FaultOfflineLabel}" />
                                    <TextBlock Grid.Column="3" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding FaultPlaybackLabel}" />
                                    <TextBlock Grid.Column="4" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding FaultImageLabel}" />
                                    <TextBlock Grid.Column="5" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding FaultNewLabel}" />
                                    <TextBlock Grid.Column="6" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding FaultRepeatedLabel}" />
                                </Grid>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding FilteredFaultRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type state:FaultStatisticsReportRowState}">
                                                <Border Style="{StaticResource MutedPanelStyle}" Padding="14" Margin="0,0,0,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="1*" />
                                                            <ColumnDefinition Width="1*" />
                                                            <ColumnDefinition Width="1*" />
                                                            <ColumnDefinition Width="1*" />
                                                            <ColumnDefinition Width="1*" />
                                                            <ColumnDefinition Width="1*" />
                                                            <ColumnDefinition Width="1*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Style="{StaticResource FieldValueTextStyle}" Text="{Binding ReportDateText}" />
                                                        <TextBlock Grid.Column="1" Style="{StaticResource FieldValueTextStyle}" Text="{Binding FaultTotal}" />
                                                        <TextBlock Grid.Column="2" Style="{StaticResource FieldValueTextStyle}" Text="{Binding OfflineFaults}" />
                                                        <TextBlock Grid.Column="3" Style="{StaticResource FieldValueTextStyle}" Text="{Binding PlaybackFailedFaults}" />
                                                        <TextBlock Grid.Column="4" Style="{StaticResource FieldValueTextStyle}" Text="{Binding ImageAbnormalFaults}" />
                                                        <TextBlock Grid.Column="5" Style="{StaticResource FieldValueTextStyle}" Text="{Binding NewFaults}" />
                                                        <TextBlock Grid.Column="6" Style="{StaticResource FieldValueTextStyle}" Text="{Binding RepeatedFaults}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource PrimaryPanelStyle}" Visibility="{Binding IsDispatchDisposalSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding DispatchDateLabel}" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding DispatchPendingLabel}" />
                                    <TextBlock Grid.Column="2" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding DispatchDispatchedLabel}" />
                                    <TextBlock Grid.Column="3" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding DispatchRecoveredLabel}" />
                                    <TextBlock Grid.Column="4" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding DispatchUnrecoveredLabel}" />
                                    <TextBlock Grid.Column="5" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding DispatchAutomaticLabel}" />
                                    <TextBlock Grid.Column="6" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding DispatchManualLabel}" />
                                </Grid>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding FilteredDispatchRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type state:DispatchDisposalReportRowState}">
                                                <Border Style="{StaticResource MutedPanelStyle}" Padding="14" Margin="0,0,0,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="1*" />
                                                            <ColumnDefinition Width="1*" />
                                                            <ColumnDefinition Width="1*" />
                                                            <ColumnDefinition Width="1*" />
                                                            <ColumnDefinition Width="1*" />
                                                            <ColumnDefinition Width="1*" />
                                                            <ColumnDefinition Width="1*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Style="{StaticResource FieldValueTextStyle}" Text="{Binding ReportDateText}" />
                                                        <TextBlock Grid.Column="1" Style="{StaticResource FieldValueTextStyle}" Text="{Binding PendingDispatchCount}" />
                                                        <TextBlock Grid.Column="2" Style="{StaticResource FieldValueTextStyle}" Text="{Binding DispatchedCount}" />
                                                        <TextBlock Grid.Column="3" Style="{StaticResource FieldValueTextStyle}" Text="{Binding RecoveredCount}" />
                                                        <TextBlock Grid.Column="4" Style="{StaticResource FieldValueTextStyle}" Text="{Binding UnrecoveredCount}" />
                                                        <TextBlock Grid.Column="5" Style="{StaticResource FieldValueTextStyle}" Text="{Binding AutomaticDispatchCount}" />
                                                        <TextBlock Grid.Column="6" Style="{StaticResource FieldValueTextStyle}" Text="{Binding ManualDispatchCount}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource PrimaryPanelStyle}" Visibility="{Binding IsResponsibilitySelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.4*" />
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding ResponsibilityUnitLabel}" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding ResponsibilityMaintainerLabel}" />
                                    <TextBlock Grid.Column="2" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding ResponsibilitySupervisorLabel}" />
                                    <TextBlock Grid.Column="3" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding ResponsibilityFaultCountLabel}" />
                                    <TextBlock Grid.Column="4" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding ResponsibilityRecoveredLabel}" />
                                    <TextBlock Grid.Column="5" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding ResponsibilityUnrecoveredLabel}" />
                                </Grid>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding FilteredResponsibilityRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type state:ResponsibilityOwnershipReportRowState}">
                                                <Border Style="{StaticResource MutedPanelStyle}" Padding="14" Margin="0,0,0,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="1.4*" />
                                                            <ColumnDefinition Width="1*" />
                                                            <ColumnDefinition Width="1*" />
                                                            <ColumnDefinition Width="1*" />
                                                            <ColumnDefinition Width="1*" />
                                                            <ColumnDefinition Width="1*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Style="{StaticResource FieldValueTextStyle}" Text="{Binding CurrentHandlingUnit}" TextWrapping="Wrap" />
                                                        <TextBlock Grid.Column="1" Style="{StaticResource FieldValueTextStyle}" Text="{Binding MaintainerName}" />
                                                        <TextBlock Grid.Column="2" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SupervisorName}" />
                                                        <TextBlock Grid.Column="3" Style="{StaticResource FieldValueTextStyle}" Text="{Binding FaultCount}" />
                                                        <TextBlock Grid.Column="4" Style="{StaticResource FieldValueTextStyle}" Text="{Binding RecoveredCount}" />
                                                        <TextBlock Grid.Column="5" Style="{StaticResource FieldValueTextStyle}" Text="{Binding UnrecoveredCount}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource PrimaryPanelStyle}" Visibility="{Binding IsOutstandingSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="1.1*" />
                                        <ColumnDefinition Width="0.9*" />
                                        <ColumnDefinition Width="0.9*" />
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="1.05*" />
                                        <ColumnDefinition Width="1.05*" />
                                        <ColumnDefinition Width="0.9*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding OutstandingPointLabel}" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding OutstandingUnitLabel}" />
                                    <TextBlock Grid.Column="2" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding OutstandingMaintainerLabel}" />
                                    <TextBlock Grid.Column="3" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding OutstandingSupervisorLabel}" />
                                    <TextBlock Grid.Column="4" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding OutstandingFaultTypeLabel}" />
                                    <TextBlock Grid.Column="5" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding OutstandingFirstFaultLabel}" />
                                    <TextBlock Grid.Column="6" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding OutstandingLatestFaultLabel}" />
                                    <TextBlock Grid.Column="7" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding OutstandingStatusLabel}" />
                                </Grid>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding FilteredOutstandingRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type state:OutstandingFaultReportRowState}">
                                                <Border Style="{StaticResource MutedPanelStyle}" Padding="14" Margin="0,0,0,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="1.2*" />
                                                            <ColumnDefinition Width="1.1*" />
                                                            <ColumnDefinition Width="0.9*" />
                                                            <ColumnDefinition Width="0.9*" />
                                                            <ColumnDefinition Width="1.2*" />
                                                            <ColumnDefinition Width="1.05*" />
                                                            <ColumnDefinition Width="1.05*" />
                                                            <ColumnDefinition Width="0.9*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Style="{StaticResource FieldValueTextStyle}" Text="{Binding PointName}" TextWrapping="Wrap" />
                                                        <TextBlock Grid.Column="1" Style="{StaticResource FieldValueTextStyle}" Text="{Binding CurrentHandlingUnit}" TextWrapping="Wrap" />
                                                        <TextBlock Grid.Column="2" Style="{StaticResource FieldValueTextStyle}" Text="{Binding MaintainerName}" />
                                                        <TextBlock Grid.Column="3" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SupervisorName}" />
                                                        <TextBlock Grid.Column="4" Style="{StaticResource FieldValueTextStyle}" Text="{Binding FaultType}" TextWrapping="Wrap" />
                                                        <TextBlock Grid.Column="5" Style="{StaticResource FieldValueTextStyle}" Text="{Binding FirstFaultTime}" />
                                                        <TextBlock Grid.Column="6" Style="{StaticResource FieldValueTextStyle}" Text="{Binding LatestFaultTime}" />
                                                        <TextBlock Grid.Column="7" Style="{StaticResource FieldValueTextStyle}" Text="{Binding CurrentStatus}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>

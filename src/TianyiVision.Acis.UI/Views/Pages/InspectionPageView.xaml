<UserControl x:Class="TianyiVision.Acis.UI.Views.Pages.InspectionPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:TianyiVision.Acis.UI.Views.Controls"
             xmlns:state="clr-namespace:TianyiVision.Acis.UI.States"
             xmlns:views="clr-namespace:TianyiVision.Acis.UI.Views.Pages"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">
    <UserControl.Resources>
        <Style x:Key="WorkspaceVisibilityStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsReviewWallVisible}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ReviewVisibilityStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsReviewWallVisible}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="InspectionSectionCardStyle" TargetType="Border" BasedOn="{StaticResource PrimaryPanelStyle}">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>
        <Style x:Key="GroupItemButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Theme.SelectionBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.SelectionBorderBrush}" />
                    <Setter Property="BorderThickness" Value="2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PointItemButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="14,12" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static state:InspectionPointStatus.Fault}">
                    <Setter Property="Background" Value="{DynamicResource Theme.DangerSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.DangerBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static state:InspectionPointStatus.PausedUntilRecovery}">
                    <Setter Property="Background" Value="{DynamicResource Theme.DangerSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.DangerBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static state:InspectionPointStatus.Inspecting}">
                    <Setter Property="Background" Value="{DynamicResource Theme.InspectionActiveSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.InspectionActiveBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Theme.SelectionBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.SelectionBorderBrush}" />
                    <Setter Property="BorderThickness" Value="2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ScopeUnmatchedPointButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Background" Value="{DynamicResource Theme.WarningSoftBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.WarningBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Theme.SelectionBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.SelectionBorderBrush}" />
                    <Setter Property="BorderThickness" Value="2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid Style="{StaticResource WorkspaceVisibilityStyle}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Margin="0,0,0,20">
                <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="{Binding Title}" />
                <TextBlock Margin="0,10,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding Description}" TextWrapping="Wrap" />
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="460" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,18,0">
                        <Border Style="{StaticResource InspectionSectionCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding GroupSectionTitle}" />
                                <TextBlock Margin="0,8,0,16" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding GroupSectionDescription}" TextWrapping="Wrap" />
                                <Border Style="{StaticResource MutedPanelStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding CurrentGroupLabel}" />
                                        <TextBlock Margin="0,8,0,0" FontSize="18" FontWeight="SemiBold" Text="{Binding SelectedGroup.Name, TargetNullValue=--}" />
                                        <TextBlock Margin="0,8,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding SelectedGroup.Summary, TargetNullValue=--}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <DockPanel Margin="0,16,0,12">
                                    <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding AvailableGroupsLabel}" />
                                    <Button DockPanel.Dock="Right" Padding="12,8" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding ToggleGroupCommand}" Content="{Binding ToggleGroupActionText}" />
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding Groups}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource GroupItemButtonStyle}" Command="{Binding DataContext.SelectGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                <StackPanel>
                                                    <TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding Name}" />
                                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding Summary}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource InspectionSectionCardStyle}" Margin="0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding TasksSectionTitle}" />
                                <TextBlock Margin="0,8,0,16" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding TasksSectionDescription}" TextWrapping="Wrap" />
                                <Border Style="{StaticResource MutedPanelStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="110" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="{Binding TaskNameLabel}" />
                                        <TextBlock Grid.Column="1" Style="{StaticResource FieldValueTextStyle}" Text="{Binding CurrentTask.TaskName, TargetNullValue=--}" />
                                        <TextBlock Grid.Row="1" Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding ExecutionTaskStatusLabel}" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding ExecutionState.CurrentTaskStatus, TargetNullValue=--}" />
                                        <TextBlock Grid.Row="2" Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding TaskCurrentPointLabel}" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding ExecutionState.CurrentPointName, TargetNullValue=--}" />
                                        <TextBlock Grid.Row="3" Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding ExecutionProgressLabel}" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding ExecutionState.CurrentProgressText, TargetNullValue=0 / 0}" />
                                        <TextBlock Grid.Row="4" Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding TaskSummaryLabel}" />
                                        <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding CurrentTask.Summary, TargetNullValue=--}" TextWrapping="Wrap" />
                                    </Grid>
                                </Border>
                                <TextBlock Margin="0,16,0,10" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding TaskRecentListLabel}" />
                                <ItemsControl ItemsSource="{Binding RecentTasks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10" Padding="12" Background="{DynamicResource Theme.PanelMutedBackgroundBrush}" BorderBrush="{DynamicResource Theme.PanelBorderBrush}" BorderThickness="1" CornerRadius="12">
                                                <StackPanel>
                                                    <DockPanel LastChildFill="False">
                                                        <TextBlock FontWeight="SemiBold" Text="{Binding TaskName}" />
                                                        <TextBlock DockPanel.Dock="Right" Style="{StaticResource FieldValueTextStyle}" Text="{Binding StatusText}" />
                                                    </DockPanel>
                                                    <TextBlock Margin="0,8,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding Summary}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,18,0">
                        <Border Style="{StaticResource InspectionSectionCardStyle}" Margin="0">
                            <StackPanel>
                                <DockPanel LastChildFill="False">
                                    <StackPanel Width="290">
                                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding WorkbenchTitle}" />
                                        <TextBlock Margin="0,8,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding WorkbenchDescription}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button DockPanel.Dock="Right" Padding="16,10" Style="{StaticResource PrimaryActionButtonStyle}" Command="{Binding ExecuteInspectionCommand}" Content="{Binding ExecuteInspectionText}" />
                                </DockPanel>
                                <Border Margin="0,18,0,14" Style="{StaticResource MutedPanelStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="{Binding CurrentGroupLabel}" />
                                        <TextBlock Grid.Column="1" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedGroup.Name, TargetNullValue=--}" />
                                        <TextBlock Grid.Row="1" Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding TaskCurrentPointLabel}" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding ExecutionState.CurrentPointName, TargetNullValue=--}" />
                                    </Grid>
                                </Border>
                                <Border Margin="0,0,0,14" Style="{StaticResource MutedPanelStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding ScopePreviewTitle}" />
                                        <TextBlock Margin="0,8,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding ScopePreviewDescription}" TextWrapping="Wrap" />
                                        <Grid Margin="0,16,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="{Binding ScopePlanNameLabel}" />
                                            <TextBlock Grid.Column="1" Style="{StaticResource FieldValueTextStyle}" Text="{Binding ScopePlanPreview.PlanName, TargetNullValue=--}" />
                                            <TextBlock Grid.Row="1" Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding ScopeMatchedCountLabel}" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding ScopePlanPreview.MatchedPointCount, StringFormat={}{0} 个}" />
                                            <TextBlock Grid.Row="2" Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding ScopeUnmatchedCountLabel}" />
                                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding ScopePlanPreview.UnmatchedPointCount, StringFormat={}{0} 个}" />
                                            <TextBlock Grid.Row="3" Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding ScopeRuleSummaryLabel}" />
                                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding ScopePlanPreview.RuleSummary}" TextWrapping="Wrap" />
                                            <TextBlock Grid.Row="4" Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding ScopeExecutionSummaryLabel}" />
                                            <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding ScopePlanPreview.ExecutionSummary}" TextWrapping="Wrap" />
                                            <TextBlock Grid.Row="5" Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding ScopeUnmatchedReasonLabel}" />
                                            <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding ScopePlanPreview.UnmatchedReasonSummary}" TextWrapping="Wrap" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <TextBlock Margin="0,0,0,10" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding ScopeMatchedListLabel}" />
                                <ItemsControl ItemsSource="{Binding ScopeMatchedPoints}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource PointItemButtonStyle}" Command="{Binding DataContext.SelectPointCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                <StackPanel>
                                                    <DockPanel LastChildFill="False">
                                                        <StackPanel Width="250">
                                                            <TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding Name}" />
                                                            <TextBlock Margin="0,4,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding DeviceCode}" />
                                                        </StackPanel>
                                                        <TextBlock DockPanel.Dock="Right" Style="{StaticResource FieldValueTextStyle}" Text="{Binding StatusText}" />
                                                    </DockPanel>
                                                    <TextBlock Margin="0,10,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding ScopeDecisionSummary}" TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding OnlineStatus}" />
                                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding PlaybackStatus}" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <StackPanel Visibility="{Binding HasScopeUnmatchedPoints, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Margin="0,10,0,10" Style="{StaticResource SectionLabelTextStyle}" Text="{Binding ScopeUnmatchedListLabel}" />
                                    <ItemsControl ItemsSource="{Binding ScopeUnmatchedPoints}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource ScopeUnmatchedPointButtonStyle}" Command="{Binding DataContext.SelectPointCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                    <StackPanel>
                                                        <DockPanel LastChildFill="False">
                                                            <StackPanel Width="250">
                                                                <TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding Name}" />
                                                                <TextBlock Margin="0,4,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding DeviceCode}" />
                                                            </StackPanel>
                                                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource FieldValueTextStyle}" Text="{Binding UnitName}" />
                                                        </DockPanel>
                                                        <TextBlock Margin="0,10,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding ScopeDecisionSummary}" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource InspectionSectionCardStyle}" Margin="0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding DetailsSectionTitle}" />
                                <TextBlock Margin="0,8,0,16" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding DetailsSectionDescription}" TextWrapping="Wrap" />
                                <Border Style="{StaticResource MutedPanelStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="120" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailPointNameLabel}" />
                                        <TextBlock Grid.Column="1" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedPointDetail.PointName, TargetNullValue=--}" />
                                        <TextBlock Grid.Row="1" Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailUnitLabel}" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedPointDetail.UnitName, TargetNullValue=--}" />
                                        <TextBlock Grid.Row="2" Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailCurrentStatusLabel}" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedPointDetail.CurrentStatus, TargetNullValue=--}" />
                                        <TextBlock Grid.Row="3" Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailOnlineLabel}" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedPointDetail.OnlineStatus, TargetNullValue=--}" />
                                        <TextBlock Grid.Row="4" Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding DetailPlaybackLabel}" />
                                        <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SelectedPointDetail.PlaybackStatus, TargetNullValue=--}" />
                                        <TextBlock Grid.Row="5" Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding LastConclusionLabel}" />
                                        <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding SelectedPointDetail.LastInspectionConclusion, TargetNullValue=--}" TextWrapping="Wrap" />
                                    </Grid>
                                </Border>
                                <Border Margin="0,14,0,0" Style="{StaticResource MutedPanelStyle}">
                                    <StackPanel>
                                        <DockPanel LastChildFill="False">
                                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding SinglePointInspectionTitle}" />
                                            <Button DockPanel.Dock="Right" Padding="14,10" Style="{StaticResource PrimaryActionButtonStyle}" Command="{Binding StartSinglePointInspectionCommand}" Content="{Binding SinglePointInspectionActionText}" />
                                        </DockPanel>
                                        <Grid Margin="0,16,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="120" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="{Binding SinglePointInspectionPointNameLabel}" />
                                            <TextBlock Grid.Column="1" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SinglePointInspectionPointName}" />
                                            <TextBlock Grid.Row="1" Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding SinglePointInspectionTaskStatusLabel}" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SinglePointInspectionTaskStatus}" />
                                            <TextBlock Grid.Row="2" Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding SinglePointInspectionLastTimeLabel}" />
                                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueTextStyle}" Text="{Binding SinglePointInspectionLastTime}" />
                                            <TextBlock Grid.Row="3" Margin="0,10,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="{Binding SinglePointInspectionResultSummaryLabel}" />
                                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding SinglePointInspectionResultSummary}" TextWrapping="Wrap" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,14,0,0" Style="{StaticResource MutedPanelStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding PreviewTitle}" />
                                        <TextBlock Margin="0,8,0,14" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding PreviewDescription}" TextWrapping="Wrap" />
                                        <Border Height="220" Background="{DynamicResource Theme.PanelMutedBackgroundBrush}" BorderBrush="{DynamicResource Theme.PanelBorderBrush}" BorderThickness="1" CornerRadius="18">
                                            <Grid>
                                                <wv2:WebView2 x:Name="PreviewWebView" Source="{Binding SelectedPointDetail.PreviewHostUri}" Visibility="{Binding SelectedPointDetail.IsPreviewAvailable, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock HorizontalAlignment="Center" Style="{StaticResource AccentTextStyle}" Text="{Binding SelectedPointDetail.PreviewBusinessTitle, TargetNullValue=--}" />
                                                    <TextBlock Margin="0,18,0,0" Width="240" TextAlignment="Center" TextWrapping="Wrap" FontSize="18" FontWeight="SemiBold" Text="{Binding SelectedPointDetail.PlaybackStatus, TargetNullValue=--}" />
                                                    <TextBlock Margin="0,18,0,0" Width="240" TextAlignment="Center" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding SelectedPointDetail.PreviewBusinessDescription, TargetNullValue=--}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
        <Grid Visibility="Collapsed" Width="0" Height="0">
            <controls:RealMapHost x:Name="RealMapHost"
                                  ItemsSource="{Binding MapPoints}"
                                  SelectedPointId="{Binding SelectedMapPointId}"
                                  PointSelectedCommand="{Binding SelectPointCommand}" />
            <Border x:Name="FallbackMapLayer" />
            <Border x:Name="PreviewFailureCard" Width="320" Height="180" Background="{DynamicResource Theme.DangerSoftBrush}" BorderBrush="{DynamicResource Theme.DangerBrush}" BorderThickness="1" CornerRadius="16">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock HorizontalAlignment="Center" Style="{StaticResource AccentTextStyle}" Text="{Binding SelectedPointDetail.PreviewBusinessTitle, TargetNullValue=--}" />
                    <TextBlock Margin="0,10,0,0" Width="220" TextAlignment="Center" TextWrapping="Wrap" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding SelectedPointDetail.PreviewBusinessDescription, TargetNullValue=--}" />
                </StackPanel>
            </Border>
        </Grid>
        <views:InspectionReviewWallView Style="{StaticResource ReviewVisibilityStyle}" />
    </Grid>
</UserControl>

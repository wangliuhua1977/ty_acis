<UserControl x:Class="TianyiVision.Acis.UI.Views.Pages.InspectionPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,20">
            <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="{Binding Title}" />
            <TextBlock Margin="0,10,0,0" Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding Description}" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <ItemsControl ItemsSource="{Binding TaskPanels}" ItemTemplate="{StaticResource PanelPlaceholderTemplate}" />

            <Border Grid.Column="1" Margin="16,0" Style="{StaticResource PrimaryPanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource AccentTextStyle}" Text="{Binding WorkbenchPanel.Accent}" />
                        <TextBlock Margin="0,10,0,6"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Theme.TextPrimaryBrush}"
                                   Text="{Binding WorkbenchPanel.Title}" />
                        <TextBlock Style="{StaticResource PageDescriptionTextStyle}" Text="{Binding WorkbenchPanel.Description}" />
                    </StackPanel>

                    <ItemsControl Grid.Row="1"
                                  Margin="0,22,0,20"
                                  ItemsSource="{Binding WorkbenchHighlights}"
                                  ItemTemplate="{StaticResource MetricCardTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <Border Grid.Row="2"
                            Background="{DynamicResource Theme.WorkbenchBackgroundBrush}"
                            BorderBrush="{DynamicResource Theme.PanelBorderStrongBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Style="{StaticResource AccentTextStyle}" Text="MAP WORKBENCH RESERVED" />
                            <TextBlock Grid.Row="1"
                                       Margin="0,20,0,20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Theme.TextSecondaryBrush}"
                                       Text="本轮不接地图，仅保留后续高德地图中台与点位联动接入位置。" />
                            <Border Grid.Row="2"
                                    Padding="14"
                                    Background="{DynamicResource Theme.AccentSoftBrush}"
                                    CornerRadius="14">
                                <TextBlock Style="{StaticResource PageDescriptionTextStyle}"
                                           Text="后续在此接入实时巡检过程、点位高亮、故障红灯闪烁和视频预览浮窗。" />
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <ItemsControl Grid.Column="2"
                          ItemsSource="{Binding DetailPanels}"
                          ItemTemplate="{StaticResource PanelPlaceholderTemplate}" />
        </Grid>
    </Grid>
</UserControl>

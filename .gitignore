# =========================
# TianyiVision.Acis .gitignore
# .NET / WPF / Visual Studio / Codex-friendly
# =========================

# -------------------------
# Build outputs
# -------------------------
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
artifacts/

# -------------------------
# Visual Studio / Rider / VS Code
# -------------------------
.vs/
.idea/
*.sln.iml
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# -------------------------
# User / machine specific
# -------------------------
*.user
*.rsuser
*.suo
*.userosscache
*.sln.docstates
*.userprefs
*.DotSettings.user

# -------------------------
# Logs / temp
# -------------------------
*.log
*.tmp
*.temp
*.cache
*.pid
*.seed
*.stackdump
*.out
*.err

# -------------------------
# NuGet / packages
# -------------------------
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/

# -------------------------
# Test / coverage
# -------------------------
[Tt]est[Rr]esult*/
coverage*.json
coverage*.xml
coverage*.info
*.coverage
*.coveragexml
BenchmarkDotNet.Artifacts/

# -------------------------
# Generated / designer / cache
# -------------------------
Generated\ Files/
Generated_Code/
_ReSharper*/
_TeamCity*
_NCrunch_*
*.VisualState.xml
TestResult.xml
nunit-*.xml
OpenCover/
.axoCover/*
!.axoCover/settings.json
.localhistory/
.history/
.vshistory/

# -------------------------
# Publish / installer outputs
# -------------------------
publish/
*.[Pp]ublish.xml
*.azurePubxml
*.pubxml
*.publishproj
PublishScripts/
AppPackages/
BundleArtifacts/
*.appx
*.appxbundle
*.appxupload
*.msix
*.msi
*.msp
*.cab

# -------------------------
# Local environment / secrets
# -------------------------
.env
.env.*
*.local.json
appsettings.local.json
appsettings.*.local.json

# -------------------------
# Local database / storage
# -------------------------
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal
*.mdf
*.ldf
*.ndf

# -------------------------
# OS files
# -------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store
.AppleDouble
.LSOverride
._*

# -------------------------
# Node / frontend leftovers
# -------------------------
node_modules/

# -------------------------
# Python leftovers
# -------------------------
__pycache__/
*.pyc

# -------------------------
# WPF temp / generated
# -------------------------
*_wpftmp.csproj
*.g.cs
*.g.i.cs
*.baml

# -------------------------
# Backup / conversion leftovers
# -------------------------
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm
_UpgradeReport_Files/
MigrationBackup/

# -------------------------
# Local history / editor swap
# -------------------------
*.swp
*.bak
*.orig
*~

# -------------------------
# Keep source, docs, templates tracked
# -------------------------
!src/**
!docs/**
!README.md
!AGENTS.md
!*.template.json

